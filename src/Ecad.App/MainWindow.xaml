<Window x:Class="Ecad.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ecad.App"
        xmlns:vm="clr-namespace:Ecad.App.ViewModels"
        xmlns:views="clr-namespace:Ecad.App.Views"
        xmlns:conv="clr-namespace:Ecad.App.Converters"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="700" Width="1200" Icon="Assets/AppIcon.ico">
    <Window.Resources>
        <!-- M10: each open document's tab content is resolved by its ViewModel's type — one
             ContentPresenter in the TabControl below, many possible Views, no manual view-locator. -->
        <DataTemplate DataType="{x:Type vm:SchematicPageViewModel}">
            <views:SchematicPageView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GridEditorViewModel}">
            <views:GridEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PartsLibraryViewModel}">
            <views:PartsLibraryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SymbolBrowserViewModel}">
            <views:SymbolBrowserView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportPageViewModel}">
            <views:ReportPageView/>
        </DataTemplate>

        <conv:EnumEqualityConverter x:Key="EnumEqualityConverter"/>
        <conv:BlankGroupLabelConverter x:Key="BlankGroupLabelConverter"/>
        <conv:BoolToColumnWidthConverter x:Key="BoolToColumnWidthConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project..." Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="_Open Project..." Command="{Binding OpenProjectCommand}"/>
                <Separator/>
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}"/>
                <MenuItem Header="_Close Project" Command="{Binding CloseProjectCommand}"/>
                <Separator/>
                <MenuItem Header="_Grid Editor" Command="{Binding OpenGridEditorCommand}"/>
                <Separator/>
                <MenuItem Header="_Import EPLAN Parts..." Command="{Binding ImportEplanPartsCommand}"/>
                <MenuItem Header="_Parts Library" Command="{Binding OpenPartsLibraryCommand}"/>
                <MenuItem Header="Symbol _Browser" Command="{Binding OpenSymbolBrowserCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Reports">
                <MenuItem Header="_Connection List" Command="{Binding GenerateConnectionListReportCommand}"/>
                <MenuItem Header="_BOM / Parts List..." Command="{Binding GenerateBomReportCommand}"/>
                <MenuItem Header="Cable _Overview" Command="{Binding GenerateCableOverviewReportCommand}"/>
                <MenuItem Header="Cable _Manufacturing Sheets" Command="{Binding GenerateCableManufacturingSheetsCommand}"/>
                <Separator/>
                <MenuItem Header="_Regenerate All Reports" Command="{Binding RegenerateAllReportsCommand}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Page Navigator" IsCheckable="True" IsChecked="{Binding IsPageNavigatorVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Devices Navigator" IsCheckable="True" IsChecked="{Binding IsDevicesNavigatorVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Cables Navigator" IsCheckable="True" IsChecked="{Binding IsCablesNavigatorVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Interruption Points Navigator" IsCheckable="True" IsChecked="{Binding IsInterruptionPointsNavigatorVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Connections Navigator" IsCheckable="True" IsChecked="{Binding IsConnectionsNavigatorVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Terminals Navigator" IsCheckable="True" IsChecked="{Binding IsTerminalsNavigatorVisible, Mode=TwoWay}"/>
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="_Preferences..." Command="{Binding OpenSettingsCommand}"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding IsPageNavigatorVisible, Converter={StaticResource BoolToColumnWidthConverter}}"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TabControl Grid.Column="0" Visibility="{Binding IsPageNavigatorVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <TabItem Header="Pages">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                    <TextBlock Text="Pages" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="Add Page..." Command="{Binding AddPageCommand}" Padding="8,2" Margin="0,0,4,0"/>
                    <Button Content="⚙" Padding="6,2" ToolTip="Page Navigator settings" Click="OnPagesSettingsClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="No Grouping" IsCheckable="True"
                                          IsChecked="{Binding PageGroupBy, Converter={StaticResource EnumEqualityConverter}, ConverterParameter={x:Static vm:PageGroupBy.None}, Mode=OneWay}"
                                          Command="{Binding SetPageGroupByCommand}" CommandParameter="{x:Static vm:PageGroupBy.None}"/>
                                <MenuItem Header="Group by Function" IsCheckable="True"
                                          IsChecked="{Binding PageGroupBy, Converter={StaticResource EnumEqualityConverter}, ConverterParameter={x:Static vm:PageGroupBy.Function}, Mode=OneWay}"
                                          Command="{Binding SetPageGroupByCommand}" CommandParameter="{x:Static vm:PageGroupBy.Function}"/>
                                <MenuItem Header="Group by Location" IsCheckable="True"
                                          IsChecked="{Binding PageGroupBy, Converter={StaticResource EnumEqualityConverter}, ConverterParameter={x:Static vm:PageGroupBy.Location}, Mode=OneWay}"
                                          Command="{Binding SetPageGroupByCommand}" CommandParameter="{x:Static vm:PageGroupBy.Location}"/>
                                <MenuItem Header="Group by Document Type" IsCheckable="True"
                                          IsChecked="{Binding PageGroupBy, Converter={StaticResource EnumEqualityConverter}, ConverterParameter={x:Static vm:PageGroupBy.DocumentType}, Mode=OneWay}"
                                          Command="{Binding SetPageGroupByCommand}" CommandParameter="{x:Static vm:PageGroupBy.DocumentType}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
                <ListView ItemsSource="{Binding Pages}" Margin="8" MouseDoubleClick="OnPagesDoubleClick"
                          SelectionMode="Extended" SelectionChanged="OnPagesSelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Function" Width="70" DisplayMemberBinding="{Binding FunctionSegment}"/>
                            <GridViewColumn Header="Location" Width="70" DisplayMemberBinding="{Binding LocationSegment}"/>
                            <GridViewColumn Header="Doc Type" Width="65" DisplayMemberBinding="{Binding DocumentTypeSegment}"/>
                            <GridViewColumn Header="Page #" Width="60" DisplayMemberBinding="{Binding PageNumberSegment}"/>
                        </GridView>
                    </ListView.View>
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="{x:Type GroupItem}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type GroupItem}">
                                                <Expander IsExpanded="True" FontWeight="Bold" Background="#EEEEEE">
                                                    <Expander.Header>
                                                        <TextBlock Text="{Binding Name, Converter={StaticResource BlankGroupLabelConverter}}" FontWeight="Bold"/>
                                                    </Expander.Header>
                                                    <ItemsPresenter Margin="16,0,0,0"/>
                                                </Expander>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </ListView.GroupStyle>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="_Rename..." Command="{Binding RenameSelectedPageCommand}"/>
                            <MenuItem Header="Re_number Selected" Command="{Binding RenumberSelectedPagesCommand}"/>
                            <Separator/>
                            <MenuItem Header="_Delete Selected" Command="{Binding DeleteSelectedPagesCommand}"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                </ListView>
            </DockPanel>
            </TabItem>
            <TabItem Header="Devices" Visibility="{Binding IsDevicesNavigatorVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <views:DevicesNavigatorView DataContext="{Binding DevicesNavigator}"/>
            </TabItem>
            <TabItem Header="Cables" Visibility="{Binding IsCablesNavigatorVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <views:CablesNavigatorView DataContext="{Binding CablesNavigator}"/>
            </TabItem>
            <TabItem Header="Interruption Points" Visibility="{Binding IsInterruptionPointsNavigatorVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <views:DevicesNavigatorView DataContext="{Binding InterruptionPointsNavigator}"/>
            </TabItem>
            <TabItem Header="Connections" Visibility="{Binding IsConnectionsNavigatorVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <views:ConnectionsNavigatorView DataContext="{Binding ConnectionsNavigator}"/>
            </TabItem>
            <TabItem Header="Terminals" Visibility="{Binding IsTerminalsNavigatorVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <views:TerminalsNavigatorView DataContext="{Binding TerminalsNavigator}"/>
            </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="LightGray"
                          Visibility="{Binding IsPageNavigatorVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TabControl Grid.Column="2" ItemsSource="{Binding OpenTabs}" SelectedItem="{Binding SelectedTab}">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Header}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="✕" Padding="4,0" FontSize="10"
                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <ContentPresenter Content="{Binding Content}"/>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
