<Window x:Class="Ecad.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ecad.App"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="600" Width="900">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project..." Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="_Open Project..." Command="{Binding OpenProjectCommand}"/>
                <Separator/>
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}"/>
                <MenuItem Header="_Close Project" Command="{Binding CloseProjectCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>

        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                <TextBlock Text="Pages" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="Add Page..." Command="{Binding AddPageCommand}" Padding="8,2"/>
            </StackPanel>
            <ListView ItemsSource="{Binding Pages}" Margin="8">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Function" Width="100" DisplayMemberBinding="{Binding FunctionSegment}"/>
                        <GridViewColumn Header="Location" Width="100" DisplayMemberBinding="{Binding LocationSegment}"/>
                        <GridViewColumn Header="Document Type" Width="120" DisplayMemberBinding="{Binding DocumentTypeSegment}"/>
                        <GridViewColumn Header="Page Number" Width="100" DisplayMemberBinding="{Binding PageNumberSegment}"/>
                        <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding PageType}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>
    </DockPanel>
</Window>
