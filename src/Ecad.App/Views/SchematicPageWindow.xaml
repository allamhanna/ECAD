<Window x:Class="Ecad.App.Views.SchematicPageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="{Binding StatusText}" Height="650" Width="950">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <Button Content="Undo" Command="{Binding UndoCommand}" Padding="8,2" Margin="0,0,8,0"/>
            <Button Content="Redo" Command="{Binding RedoCommand}" Padding="8,2" Margin="0,0,8,0"/>
            <TextBlock Text="Click a symbol to place it. Drag to move. R to rotate, Delete to remove, right-drag to pan, wheel to zoom."
                       VerticalAlignment="Center" Foreground="Gray" Margin="8,0,0,0"/>
        </StackPanel>

        <Border DockPanel.Dock="Left" Width="120" BorderBrush="LightGray" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding PaletteItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectPaletteSymbolCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Symbol}"
                                    Margin="6" Padding="4">
                                <StackPanel>
                                    <Image Source="{Binding Thumbnail}" Width="48" Height="48"/>
                                    <TextBlock Text="{Binding Symbol.Definition.Name}" TextWrapping="Wrap"
                                               TextAlignment="Center" FontSize="10" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <skia:SKElement x:Name="SkiaCanvas" Focusable="True" IgnorePixelScaling="True"
                         PaintSurface="OnPaintSurface"
                         MouseDown="OnMouseDown"
                         MouseMove="OnMouseMove"
                         MouseUp="OnMouseUp"
                         MouseWheel="OnMouseWheel"
                         KeyDown="OnKeyDown"/>
    </DockPanel>
</Window>
