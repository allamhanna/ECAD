<UserControl x:Class="Ecad.App.Views.TerminalsNavigatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Filter — Cross-section (mm²):" Margin="0,0,0,4"/>
            <TextBox Text="{Binding FilterCrossSectionMm2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
            <TextBlock Text="Termination type:" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding TerminationTypeFilterOptions}" SelectedItem="{Binding FilterTerminationType}" Margin="0,0,0,4"/>
            <CheckBox Content="Unassigned only" IsChecked="{Binding FilterUnassignedOnly}" Margin="0,0,0,4"/>
            <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}" Padding="8,2" HorizontalAlignment="Left" Margin="0,0,0,8"/>

            <TextBlock Text="Bulk-assign termination part to selected:" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding AllParts}" SelectedItem="{Binding BulkAssignPart}" DisplayMemberPath="ExternalKey" Margin="0,0,0,4"/>
            <Button Content="Apply" Command="{Binding ApplyBulkAssignPartCommand}" Padding="8,2" HorizontalAlignment="Left"/>
        </StackPanel>

        <DataGrid x:Name="Grid" ItemsSource="{Binding FilteredRows}" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" SelectionMode="Extended" SelectionUnit="FullRow"
                  SelectionChanged="OnSelectionChanged" MouseDoubleClick="OnMouseDoubleClick"
                  PreviewMouseRightButtonDown="OnPreviewRightButtonDown">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Wire #" Binding="{Binding WireNumber}" Width="45"/>
                <DataGridTextColumn Header="This End" Binding="{Binding EndPointLabel}" Width="*"/>
                <DataGridTextColumn Header="Other End" Binding="{Binding OtherEndPointLabel}" Width="*"/>
                <DataGridCheckBoxColumn Header="Term." Binding="{Binding TerminationEnabled}" Width="40"/>
                <DataGridTextColumn Header="Type" Binding="{Binding TerminationType}" Width="70"/>
                <DataGridTextColumn Header="Part" Binding="{Binding TerminationPartExternalKey}" Width="*"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="_Edit Termination..." Click="OnEditTerminationClick"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </DockPanel>
</UserControl>
