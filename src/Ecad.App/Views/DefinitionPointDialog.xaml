<Window x:Class="Ecad.App.Views.DefinitionPointDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wire Definition Point" Height="300" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Wire Number" Grid.Row="0" Margin="0,0,0,4"/>
        <TextBox x:Name="NumberBox" Grid.Row="1" Margin="0,0,0,8"/>

        <TextBlock Text="Cross-section (mm²)" Grid.Row="2" Margin="0,0,0,4"/>
        <TextBox x:Name="CrossSectionBox" Grid.Row="3" Margin="0,0,0,8"/>

        <TextBlock Text="Color" Grid.Row="4" Margin="0,0,0,4"/>
        <TextBox x:Name="ColorBox" Grid.Row="5"/>

        <TextBlock x:Name="ValidationText" Foreground="Red" Grid.Row="6"
                   TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,4,0,0" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="7" Margin="0,8,0,0">
            <Button x:Name="RemoveButton" Content="Remove" Width="80" Margin="0,0,8,0" Click="OnRemoveClick"/>
            <Button Content="OK" Width="80" Margin="0,0,8,0" Click="OnOkClick" IsDefault="True"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
