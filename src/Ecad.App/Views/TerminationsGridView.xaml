<UserControl x:Class="Ecad.App.Views.TerminationsGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Filter — Cross-section (mm²):" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox Text="{Binding FilterCrossSectionMm2, UpdateSourceTrigger=PropertyChanged}" Width="70" VerticalAlignment="Center"/>
            <TextBlock Text="Termination type:" VerticalAlignment="Center" Margin="12,0,4,0"/>
            <ComboBox ItemsSource="{Binding TerminationTypeFilterOptions}" SelectedItem="{Binding FilterTerminationType}" Width="120" VerticalAlignment="Center"/>
            <CheckBox Content="Unassigned only" IsChecked="{Binding FilterUnassignedOnly}" VerticalAlignment="Center" Margin="12,0,0,0"/>
            <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}" Margin="12,0,0,0" Padding="8,2"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Bulk-assign termination part to selected:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox ItemsSource="{Binding AllParts}" SelectedItem="{Binding BulkAssignPart}"
                      DisplayMemberPath="ExternalKey" Width="200" VerticalAlignment="Center"/>
            <Button Content="Apply" Command="{Binding ApplyBulkAssignPartCommand}" Margin="8,0,0,0" Padding="8,2"/>
        </StackPanel>

        <DataGrid x:Name="Grid" ItemsSource="{Binding FilteredRows}" AutoGenerateColumns="False" CanUserAddRows="False"
                  SelectionMode="Extended" SelectionUnit="FullRow"
                  SelectionChanged="OnSelectionChanged" RowEditEnding="OnRowEditEnding">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Wire #" Binding="{Binding WireNumber}" Width="60" IsReadOnly="True"/>
                <DataGridTextColumn Header="End" Binding="{Binding End}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="This End" Binding="{Binding EndPointLabel}" Width="160" IsReadOnly="True"/>
                <DataGridTextColumn Header="Other End" Binding="{Binding OtherEndPointLabel}" Width="160" IsReadOnly="True"/>
                <DataGridTextColumn Header="Cross-section (mm²)" Binding="{Binding CrossSectionMm2}" Width="120" IsReadOnly="True"/>
                <DataGridCheckBoxColumn Header="Terminated" Binding="{Binding TerminationEnabled}" Width="70"/>
                <DataGridComboBoxColumn Header="Type" Width="110"
                                         SelectedItemBinding="{Binding TerminationType}"
                                         ItemsSource="{Binding DataContext.TerminationTypeOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                <DataGridTextColumn Header="Part" Binding="{Binding TerminationPartExternalKey}" Width="140" IsReadOnly="True"/>
                <DataGridTextColumn Header="Stripping Length (mm)" Binding="{Binding StrippingLengthMm}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
