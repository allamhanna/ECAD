<Window x:Class="Ecad.App.Views.EditConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Ecad.App.Converters"
        Title="Edit Connection" Height="360" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Window.Resources>
        <converters:CableCoreOptionsConverter x:Key="CableCoreOptionsConverter"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="From Pin" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox x:Name="FromPinCombo" Grid.Row="0" Grid.Column="1" Margin="0,4"
                  DisplayMemberPath="Label" SelectedValuePath="PinId"/>

        <TextBlock Text="To Pin" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox x:Name="ToPinCombo" Grid.Row="1" Grid.Column="1" Margin="0,4"
                  DisplayMemberPath="Label" SelectedValuePath="PinId"/>

        <TextBlock Text="Color" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox x:Name="ColorBox" Grid.Row="2" Grid.Column="1" Margin="0,4"/>

        <TextBlock Text="Cross-section (mm²)" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox x:Name="CrossSectionBox" Grid.Row="3" Grid.Column="1" Margin="0,4"/>

        <TextBlock Text="Length (mm)" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox x:Name="LengthBox" Grid.Row="4" Grid.Column="1" Margin="0,4"/>

        <TextBlock Text="Cable" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox x:Name="CableCombo" Grid.Row="5" Grid.Column="1" Margin="0,4"
                  DisplayMemberPath="Tag" SelectedValuePath="Id" SelectionChanged="OnCableSelectionChanged"/>

        <TextBlock Text="Cable Core" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox x:Name="CableCoreCombo" Grid.Row="6" Grid.Column="1" Margin="0,4"
                  DisplayMemberPath="CoreNumber" SelectedValuePath="Id"/>

        <TextBlock x:Name="ValidationText" Foreground="Red" Grid.Row="7" Grid.ColumnSpan="2"
                   VerticalAlignment="Top" TextWrapping="Wrap" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="8" Grid.ColumnSpan="2" Margin="0,8,0,0">
            <Button Content="OK" Width="80" Margin="0,0,8,0" Click="OnOkClick" IsDefault="True"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
