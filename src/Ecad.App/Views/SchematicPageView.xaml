<UserControl x:Class="Ecad.App.Views.SchematicPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <Button Content="Undo" Command="{Binding UndoCommand}" Padding="8,2" Margin="0,0,8,0"/>
            <Button Content="Redo" Command="{Binding RedoCommand}" Padding="8,2" Margin="0,0,8,0"/>
            <Button Content="Renumber Wires" Command="{Binding RenumberWiresCommand}" Padding="8,2" Margin="0,0,8,0"/>
            <ToggleButton Content="Place Definition Point" IsChecked="{Binding IsPlacingDefinitionPoint}" Padding="8,2" Margin="0,0,8,0"/>
            <ToggleButton Content="Draw Cable Line" IsChecked="{Binding IsDrawingCableLine}" Padding="8,2" Margin="0,0,8,0"/>
            <TextBlock Text="Grid:" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <ComboBox ItemsSource="{Binding GridSpacingOptions}" SelectedItem="{Binding GridSpacing}" Width="55" VerticalAlignment="Center"/>
            <TextBlock Text="Click a symbol to place it, or a pin to draw a wire. Drag to move, or drag on empty space to select multiple. A wire shows nothing until you toggle 'Place Definition Point' and click it. 'Draw Cable Line' drags a line across wires to assign them to a cable. R to rotate, Delete to remove, right-click for options, middle-drag to pan, wheel to zoom."
                       VerticalAlignment="Center" Foreground="Gray" Margin="8,0,0,0"/>
        </StackPanel>

        <Border DockPanel.Dock="Left" Width="120" BorderBrush="LightGray" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding PaletteItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectPaletteSymbolCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Symbol}"
                                    PreviewMouseLeftButtonDown="OnPaletteItemPreviewMouseDown"
                                    PreviewMouseMove="OnPaletteItemPreviewMouseMove"
                                    Margin="6" Padding="4">
                                <StackPanel>
                                    <Image Source="{Binding Thumbnail}" Width="48" Height="48"/>
                                    <TextBlock Text="{Binding Symbol.Definition.Name}" TextWrapping="Wrap"
                                               TextAlignment="Center" FontSize="10" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- M10 Phase 4: docked, non-modal device-properties panel — replaces the modal DeviceTagDialog
             only for renaming an existing placement (double-click); new-placement's tag prompt and
             wire-rename both stay their existing modal dialogs. Visible only while IsDevicePanelOpen. -->
        <Border DockPanel.Dock="Right" Width="220" BorderBrush="LightGray" BorderThickness="1,0,0,0"
                Visibility="{Binding IsDevicePanelOpen, Converter={StaticResource BoolToVis}}">
            <StackPanel Margin="12">
                <TextBlock Text="Device" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>

                <TextBlock Text="Function (=)" Margin="0,0,0,2"/>
                <TextBox Text="{Binding DevicePanelFunction, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Text="Location (+)" Margin="0,0,0,2"/>
                <TextBox Text="{Binding DevicePanelLocation, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Text="Designation (-)" Margin="0,0,0,2"/>
                <TextBox Text="{Binding DevicePanelDesignation, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Text="Tag" Margin="0,8,0,2"/>
                <TextBlock Text="{Binding DevicePanelPreviewTag}" FontWeight="Bold" Margin="0,0,0,12"/>

                <TextBlock Text="{Binding DevicePanelValidationText}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Apply" Width="70" Margin="0,0,8,0" Command="{Binding ApplyDeviceEditCommand}" IsDefault="True"/>
                    <Button Content="Close" Width="70" Command="{Binding CloseDevicePanelCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid>
            <skia:SKElement x:Name="SkiaCanvas" Focusable="True" IgnorePixelScaling="True" AllowDrop="True"
                             PaintSurface="OnPaintSurface"
                             MouseDown="OnMouseDown"
                             MouseMove="OnMouseMove"
                             MouseUp="OnMouseUp"
                             MouseWheel="OnMouseWheel"
                             LostMouseCapture="OnLostMouseCapture"
                             KeyDown="OnKeyDown"
                             DragOver="OnCanvasDragOver"
                             Drop="OnCanvasDrop">
                <skia:SKElement.ContextMenu>
                    <!-- A ContextMenu is a separate popup, not part of the main visual tree, so it doesn't
                         inherit SkiaCanvas's DataContext automatically — PlacementTarget re-establishes it.
                         Right-click (OnMouseDown) already selected whatever's under the cursor by the time
                         WPF opens this on the matching MouseUp, so these act on the right target. -->
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Rotate" Command="{Binding RotateSelectionCommand}"/>
                        <MenuItem Header="Delete" Command="{Binding DeleteSelectionCommand}"/>
                        <Separator/>
                        <MenuItem Header="Undo" Command="{Binding UndoCommand}"/>
                        <MenuItem Header="Redo" Command="{Binding RedoCommand}"/>
                    </ContextMenu>
                </skia:SKElement.ContextMenu>
            </skia:SKElement>

            <!-- M14 Part 3: permanent, low-cost frame-timing readout (see SchematicPageView.xaml.cs's
                 OnPaintSurface and SchematicPageViewModel.RecordFrameTiming) — left on rather than
                 instrumented-then-removed, so a future perf regression is visible without re-adding it. -->
            <TextBlock Text="{Binding FrameDiagnosticsText}" IsHitTestVisible="False"
                       Foreground="Gray" Opacity="0.6" FontSize="11"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,4"/>
        </Grid>
    </DockPanel>
</UserControl>
