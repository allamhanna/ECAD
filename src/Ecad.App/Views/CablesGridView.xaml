<UserControl x:Class="Ecad.App.Views.CablesGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="New cable — Tag:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding NewTag, UpdateSourceTrigger=PropertyChanged}" Width="100" VerticalAlignment="Center"/>
                <Button Content="Add Cable" Command="{Binding AddCableCommand}" Margin="8,0,0,0" Padding="8,2"/>
                <Button Content="Delete Selected" Command="{Binding DeleteSelectedCablesCommand}" Margin="16,0,0,0" Padding="8,2"/>
            </StackPanel>

            <DataGrid x:Name="CablesGrid" ItemsSource="{Binding Cables}" AutoGenerateColumns="False" CanUserAddRows="False"
                      SelectionMode="Extended" SelectionUnit="FullRow"
                      SelectedItem="{Binding SelectedCable}"
                      SelectionChanged="OnCableSelectionChanged" RowEditEnding="OnCableRowEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tag" Binding="{Binding Tag}" Width="80"/>
                    <DataGridTextColumn Header="Type Designation" Binding="{Binding TypeDesignation}" Width="120"/>
                    <DataGridTextColumn Header="Length (mm)" Binding="{Binding LengthMm}" Width="90"/>
                    <DataGridTextColumn Header="End-Type Classification" Binding="{Binding EndTypeClassification}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="LightGray"/>

        <DockPanel Grid.Column="2">
            <TextBlock DockPanel.Dock="Top" Text="Cores" FontWeight="Bold" Margin="0,0,0,8"/>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Add Core" Command="{Binding AddCoreCommand}" Padding="8,2"/>
                <Button Content="Delete Selected Core" Command="{Binding DeleteSelectedCoreCommand}" Margin="8,0,0,0" Padding="8,2"/>
            </StackPanel>
            <DataGrid x:Name="CoresGrid" ItemsSource="{Binding Cores}" AutoGenerateColumns="False" CanUserAddRows="False"
                      SelectedItem="{Binding SelectedCore}" RowEditEnding="OnCoreRowEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Core #" Binding="{Binding CoreNumber}" Width="60"/>
                    <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="60"/>
                    <DataGridTextColumn Header="Cross-section (mm²)" Binding="{Binding CrossSectionMm2}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</UserControl>
