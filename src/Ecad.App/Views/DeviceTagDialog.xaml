<Window x:Class="Ecad.App.Views.DeviceTagDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Device Tag" Height="330" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="DeviceLabel" Text="Device" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox x:Name="DeviceCombo" Grid.Row="0" Grid.Column="1" Margin="0,4"/>

        <TextBlock Text="Function (=)" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox x:Name="FunctionBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>

        <TextBlock Text="Location (+)" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox x:Name="LocationBox" Grid.Row="2" Grid.Column="1" Margin="0,4"/>

        <TextBlock Text="Designation (-)" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox x:Name="DesignationBox" Grid.Row="3" Grid.Column="1" Margin="0,4"/>

        <TextBlock Text="Tag" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,4"/>
        <TextBlock x:Name="PreviewText" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center"
                   FontWeight="Bold" Margin="0,8,0,4"/>

        <TextBlock x:Name="ValidationText" Foreground="Red" Grid.Row="6" Grid.ColumnSpan="2"
                   TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,4,0,0" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="8" Grid.ColumnSpan="2" Margin="0,8,0,0">
            <Button Content="OK" Width="80" Margin="0,0,8,0" Click="OnOkClick" IsDefault="True"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
