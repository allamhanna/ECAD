<UserControl x:Class="Ecad.App.Views.DevicesNavigatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8"
                    Visibility="{Binding SupportsPartAssignment, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Assign Part to selected:" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding AllParts}" SelectedItem="{Binding BulkAssignPart}"
                      DisplayMemberPath="ExternalKey"/>
            <Button Content="Apply" Command="{Binding ApplyBulkAssignPartCommand}" Margin="0,4,0,0" Padding="8,2" HorizontalAlignment="Left"/>
        </StackPanel>

        <DataGrid x:Name="Grid" ItemsSource="{Binding Devices}" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" SelectionMode="Extended" SelectionUnit="FullRow"
                  SelectionChanged="OnSelectionChanged" MouseDoubleClick="OnMouseDoubleClick"
                  PreviewMouseRightButtonDown="OnPreviewRightButtonDown">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Function" Binding="{Binding FunctionSegment}" Width="60"/>
                <DataGridTextColumn Header="Location" Binding="{Binding LocationSegment}" Width="60"/>
                <DataGridTextColumn Header="Tag" Binding="{Binding DeviceTagSegment}" Width="*"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="_Edit Tag..." Click="OnEditTagClick"/>
                    <Separator/>
                    <MenuItem Header="_Delete Selected" Command="{Binding DeleteSelectedCommand}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </DockPanel>
</UserControl>
